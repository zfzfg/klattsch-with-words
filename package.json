{
  "name": "@zfzfg/klattsch",
  "version": "0.5.0",
  "description": "Primitive parallel-formant speech synthesis engine with Text-to-Phoneme support.",
  "type": "module",
  "main": "./src/engine/index.js",
  "exports": {
    ".": "./src/engine/index.js",
    "./engine/dsp.js": "./src/engine/dsp.js",
    "./engine/synth-core.js": "./src/engine/synth-core.js",
    "./engine/sequencer.js": "./src/engine/sequencer.js",
    "./engine/phonemes.js": "./src/engine/phonemes.js",
    "./engine/wav.js": "./src/engine/wav.js",
    "./engine/g2p.js": "./src/engine/g2p.js",
    "./formant-worklet.js": "./src/formant-worklet.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src/engine/",
    "src/formant-worklet.js",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "klattsch": "./bin/klattsch.mjs"
  },
  "sideEffects": false,
  "keywords": [
    "speech-synthesis",
    "formant",
    "klatt",
    "audioworklet",
    "tts",
    "phoneme",
    "arpabet",
    "voice",
    "synthesizer",
    "text-to-speech"
  ],
  "author": "zfzfg (Original by Tony Gies)",
  "license": "MIT",
  "homepage": "https://github.com/zfzfg/klattsch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfzfg/klattsch.git"
  },
  "bugs": {
    "url": "https://github.com/zfzfg/klattsch/issues"
  },
  "scripts": {
    "dev": "python3 -m http.server 8088",
    "build:dict": "node tools/download-cmudict.js"
  }
}
